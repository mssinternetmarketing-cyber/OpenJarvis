# ─── Quantum Data ─────────────────────────────────────────────────────────────

def fmt_qdata(full=False) -> str:
    d = state.quantum_data
    if not d: return "  [no live data — run qcai_3d.py or qcai_trainer.py]"
    lines = [
        f"  step={d.get('step',0)}  cv={d.get('cv',0):.4f}  "
        f"negfrac={d.get('negfrac',0):.4f}  nc={d.get('nc_count',0)}/12",
        f"  PCM={d.get('mean_pcm',0):+.4f}  coh={d.get('coherence',0):.4f}  "
        f"ent={d.get('entropy',0):.4f}  R={d.get('reward',0):.4f}",
    ]
    if full:
        nn = ["Omega","Guardian","Sentinel","Nexus","Storm","Sora",
              "Echo","Iris","Sage","Kevin","Atlas","Void"]
        outputs = d.get("node_outputs",[])
        domains = d.get("domains",[])
        if outputs:
            lines.append("  Nodes:")
            for i,(name,out) in enumerate(zip(nn,outputs)):
                dom = domains[i] if i<len(domains) else "?"
                lines.append(f"    {name:<8}[{dom:<12}] {out}")
    return "\n".join(lines)

def build_pull_response() -> str:
    d = state.quantum_data
    if not d: return "⚛️ No live data. Start qcai_3d.py or qcai_trainer.py."
    nn = ["Omega","Guardian","Sentinel","Nexus","Storm","Sora",
          "Echo","Iris","Sage","Kevin","Atlas","Void"]
    pcms    = d.get("pcms",    [0]*12)
    phases  = d.get("phases",  [0]*12)
    outputs = d.get("node_outputs",[""]*12)
    domains = d.get("domains", ["?"]*12)
    def gl(p):
        return "🟢" if p<-0.15 else "🟡" if p<-0.05 else "🟠" if p<0.05 else "🔴"
    node_lines = "\n".join(
        f"{gl(pcms[i])} {nn[i]:<8} PCM={pcms[i]:+.3f} "
        f"φ={phases[i]:.2f} [{domains[i] if i<len(domains) else '?':<12}] "
        f"\"{outputs[i] if i<len(outputs) else ''}\""
        for i in range(min(12,len(pcms))))
    trend=""
    if len(state.data_history)>=2:
        r0=state.data_history[-2].get("reward",0)
        r1=state.data_history[-1].get("reward",0)
        trend=f"  trend:{r0:.4f}→{r1:.4f}{'↑' if r1>r0 else '↓'}"
    return (
        f"[QUANTUM_CONTEXT_UPDATE] Step {d.get('step',0)}\n"
        f"```\ncv={d.get('cv',0):.4f}  nf={d.get('negfrac',0):.4f}  "
        f"nc={d.get('nc_count',0)}/12  R={d.get('reward',0):.4f}{trend}\n```\n"
        f"*Nodes:*\n```\n{node_lines}\n```\n"
        f"_Type PULL_DATA again for updated snapshot._"
    )

