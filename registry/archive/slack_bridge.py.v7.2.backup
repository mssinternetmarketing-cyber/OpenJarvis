#!/usr/bin/env python3
"""
OpenJarvis Slack Bridge v7.2 — File Mode + Versioning + Agent Folders
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Workspace structure:
  workspace/
    current_task.md         ← input
    intake_brief.md         ← latest
    prime_plan.md           ← latest
    builder_code.py         ← latest
    physics_report.md       ← latest
    qcai_3d.py              ← latest runnable

    versions/
      intake/loop_NNN_intake.md
      prime/loop_NNN_prime.md
      builder/loop_NNN_builder.py
      physics/loop_NNN_physics.md + loop_NNN_physics.py
      output/loop_NNN_qcai_3d.py

    checkpoints/
      best_score_N.py       ← auto when Prime >= 8
      best_physics_pass.py  ← auto when Physics PASS
      manual_*.py           ← CHECKPOINT command

    logs/
      CHANGELOG.md          ← one line per loop
      metrics_log.jsonl     ← live ring time-series
      SUMMARY.md            ← Physics summary per loop

Commands: STOP|PAUSE|RESUME|SHIP IT|STATUS|PULL_DATA
Files:    LOAD_TASK|SHOW_BRIEF|SHOW_CODE|SHOW_PHYSICS|SHOW_OUTPUT
Version:  ROLLBACK <N>|CHECKPOINT|SHOW_VERSION <N>|BEST|CHANGELOG
"""

