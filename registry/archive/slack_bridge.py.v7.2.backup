# ─── Workspace Layout ─────────────────────────────────────────────────────────

WS_ROOT = "/var/home/kmonette/OpenJarvis/workspace"

WS = {
    "task":    f"{WS_ROOT}/current_task.md",
    "intake":  f"{WS_ROOT}/intake_brief.md",
    "prime":   f"{WS_ROOT}/prime_plan.md",
    "builder": f"{WS_ROOT}/builder_code.py",
