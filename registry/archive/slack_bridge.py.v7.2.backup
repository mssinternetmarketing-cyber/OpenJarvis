# ─── Loop State ───────────────────────────────────────────────────────────────

class LoopState:
    def __init__(self):
        self.running=False; self.paused=False; self.loop_count=0
        self.last_intake=self.last_prime=""
        self.last_build=self.last_physics=""
        self.original_request=""
        self.quantum_data={}
        self.data_history=deque(maxlen=10)
        self.best_score=0
        self.lock=threading.Lock()

    def reset(self):
        self.running=False; self.paused=False; self.loop_count=0
        self.last_intake=self.last_prime=""
        self.last_build=self.last_physics=""
        self.original_request=""

state = LoopState()

logging.basicConfig(level=logging.INFO,
                    format="%(asctime)s [%(levelname)s] %(message)s")
log = logging.getLogger("jarvis")
