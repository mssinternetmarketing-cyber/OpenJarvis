    "intake":  f"{WS_ROOT}/versions/intake",
    "prime":   f"{WS_ROOT}/versions/prime",
    "builder": f"{WS_ROOT}/versions/builder",
    "physics": f"{WS_ROOT}/versions/physics",
    "output":  f"{WS_ROOT}/versions/output",
}

CKPT_DIR     = f"{WS_ROOT}/checkpoints"
LOG_DIR      = f"{WS_ROOT}/logs"
CHANGELOG    = f"{LOG_DIR}/CHANGELOG.md"
METRICS_LOG  = f"{LOG_DIR}/metrics_log.jsonl"
SUMMARY_LOG  = f"{LOG_DIR}/SUMMARY.md"

def ws_init():
    """Create full workspace directory structure."""
    for path in [WS_ROOT, CKPT_DIR, LOG_DIR] + list(VER.values()):
        os.makedirs(path, exist_ok=True)
    # Initialize logs if they don't exist
    for f, header in [
        (CHANGELOG, "# QCAI Agent Loop — Changelog\n\n"),
        (SUMMARY_LOG, "# QCAI Physics Summary Log\n\n"),
    ]:
        if not os.path.exists(f):
            with open(f, "w") as fp: fp.write(header)

def ws_read(key: str) -> str:
    path = WS.get(key, f"{WS_ROOT}/{key}")
    try:
        with open(path, "r") as f: return f.read()
    except FileNotFoundError: return f"[File not found: {path}]"
    except Exception as e: return f"[Error: {e}]"

def ws_write(key: str, content: str) -> bool:
    path = WS.get(key, f"{WS_ROOT}/{key}")
    try:
        with open(path, "w") as f: f.write(content)
        log.info(f"Written: {os.path.basename(path)} ({len(content)} chars)")
        return True
    except Exception as e:
        log.error(f"Write failed {path}: {e}"); return False

def ver_write(agent: str, loop: int, content: str, ext: str = None):
    """Write versioned copy to agent's version folder."""
    exts = {"intake":"md","prime":"md","builder":"py",
             "physics":"md","output":"py"}
    if ext is None: ext = exts.get(agent, "txt")
    n    = f"{loop:03d}"
    path = f"{VER[agent]}/loop_{n}_{agent}.{ext}"
    try:
        with open(path, "w") as f: f.write(content)
        log.info(f"Version saved: {os.path.basename(path)}")
    except Exception as e:
        log.error(f"Version write failed: {e}")

def ver_read(agent: str, loop: int) -> str:
    """Read a specific loop version for an agent."""
    exts = {"intake":"md","prime":"md","builder":"py",
             "physics":"py","output":"py"}
    ext  = exts.get(agent, "txt")
    n    = f"{loop:03d}"
    path = f"{VER[agent]}/loop_{n}_{agent}.{ext}"
    try:
        with open(path, "r") as f: return f.read()
    except FileNotFoundError:
        # Try alternate extension
        for e in ["md","py","txt"]:
            p2 = f"{VER[agent]}/loop_{n}_{agent}.{e}"
            if os.path.exists(p2):
                with open(p2, "r") as f: return f.read()
        return f"[Version not found: loop {loop} {agent}]"
    except Exception as e: return f"[Error: {e}]"

def ckpt_save(name: str, content: str):
    """Save a checkpoint."""
    path = f"{CKPT_DIR}/{name}.py"
    try:
        with open(path, "w") as f: f.write(content)
        log.info(f"Checkpoint: {name}.py")
    except Exception as e: log.error(f"Checkpoint failed: {e}")

def ckpt_read(name: str) -> str:
    path = f"{CKPT_DIR}/{name}.py"
    try:
        with open(path, "r") as f: return f.read()
    except: return f"[Checkpoint not found: {name}]"

def changelog_append(loop: int, score: int, physics_status: str,
                     lines: int, summary: str):
    """Append one line to the changelog."""
    ts   = datetime.now().strftime("%Y-%m-%d %H:%M")
    line = (f"| {loop:3d} | {ts} | Score:{score:2d}/10 | "
            f"Physics:{physics_status:<7} | Lines:{lines:4d} | {summary} |\n")
    try:
        with open(CHANGELOG, "a") as f: f.write(line)
    except Exception as e: log.error(f"Changelog: {e}")

def summary_append(loop: int, report: str):
    """Append physics summary to SUMMARY.md."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    try:
        with open(SUMMARY_LOG, "a") as f:
            f.write(f"\n## Loop {loop} — {ts}\n\n{report[:500]}\n\n---\n")
    except Exception as e: log.error(f"Summary: {e}")

def metrics_append(data: dict):
    """Append quantum metrics snapshot to jsonl log."""
    data["timestamp"] = datetime.now().isoformat()
    try:
        with open(METRICS_LOG, "a") as f:
            f.write(json.dumps(data) + "\n")
    except Exception as e: log.error(f"Metrics log: {e}")

def list_versions(agent: str) -> str:
    """List available versions for an agent."""
    folder = VER.get(agent, "")
    if not folder or not os.path.exists(folder):
        return f"No versions folder for {agent}"
    files = sorted(os.listdir(folder))
    if not files: return f"No versions yet for {agent}"
    return "\n".join(f"  {f}" for f in files[-10:])  # last 10

def extract_code(text: str) -> str:
    match = re.search(r"```python\n(.*?)```", text, re.DOTALL)
    if match: return match.group(1)
    match = re.search(r"```\n(.*?)```", text, re.DOTALL)
    if match: return match.group(1)
    return text

def extract_score(text: str) -> int:
    m = re.search(r"QUALITY SCORE:\s*(\d+)/10", text)
    return int(m.group(1)) if m else 0

def extract_physics_status(text: str) -> str:
    m = re.search(r"PHYSICS STATUS:\s*(PASS|FAIL|PARTIAL)", text)
    return m.group(1) if m else "UNKNOWN"

