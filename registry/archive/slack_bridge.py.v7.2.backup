# ─── Inference ────────────────────────────────────────────────────────────────

def infer(system_prompt, user_message, temperature=0.15, max_tokens=2000):
    try:
        resp = requests.post(
            f"{OPENJARVIS_API}/v1/chat/completions",
            json={"model":MODEL,
                  "messages":[{"role":"system","content":system_prompt},
                               {"role":"user","content":user_message}],
                  "max_tokens":max_tokens,"temperature":temperature},
            timeout=300)
        resp.raise_for_status()
        return resp.json()["choices"][0]["message"]["content"].strip()
    except requests.exceptions.Timeout: return "⏱ Timed out."
    except Exception as e:
        log.error(f"Infer: {e}"); return f"❌ {e}"

# ─── Slack Helpers ────────────────────────────────────────────────────────────

def post(ch, text):
    try: return app.client.chat_postMessage(channel=ch, text=text)
    except Exception as e: log.error(f"Post failed: {e}"); return {}

def update(ch, ts, text):
    try: app.client.chat_update(channel=ch, ts=ts, text=text)
    except Exception as e: log.error(f"Update failed: {e}")

def post_agents(text):
    for ch in AGENT_CHANNELS: post(ch, text)

# ─── Loop Control + File Commands ─────────────────────────────────────────────

def wait_if_paused():
    while state.paused:
        if not state.running: return False
        time.sleep(1)
    return state.running

def handle_control(text, source_channel=None):
    raw = text.strip()
    cmd = raw.upper()
    ch  = source_channel or PHYSICS_CHANNEL_ID

    # ── Standard loop commands ──
    if cmd == "STOP":
        with state.lock: state.running=False; state.paused=False
        post_agents("🛑 *Loop stopped.* Drop new request in #jarvis-intake.")
        return True
    if cmd == "PAUSE":
        with state.lock: state.paused=True
        post_agents("⏸ *Paused.* Type RESUME.")
        return True
    if cmd == "RESUME":
        with state.lock: state.paused=False
        post_agents("▶️ *Resumed.*")
        return True
    if cmd == "SHIP IT":
        with state.lock: state.running=False
        code = ws_read("output")
        lines = code.count('\n')
        post(PHYSICS_CHANNEL_ID,
             f"🚀 *FINAL — qcai_3d.py ({lines} lines)*\n"
             f"```python\n{code[:2000]}\n```\n"
             f"_Full file: `workspace/qcai_3d.py`_")
        post_agents("✅ *Shipped. File at workspace/qcai_3d.py*")
        return True
    if cmd == "STATUS":
        # List recent versions
        out_vers = list_versions("output")
        post_agents(
            f"📊 *Loop {state.loop_count}* | "
            f"Running:{state.running} Paused:{state.paused}\n"
            f"⚛️ {fmt_qdata()}\n"
            f"📁 Recent output versions:\n{out_vers}")
        return True
    if cmd == "PULL_DATA":
        post(ch, build_pull_response())
        return True

    # ── File commands ──
    if cmd == "LOAD_TASK":
        content = ws_read("task")
        if "[File not found" in content:
            post(ch, f"❌ No task file at `{WS['task']}`")
        else:
            preview = content[:300]+"..." if len(content)>300 else content
            post(ch, f"📋 *Task loaded* ({len(content)} chars)\n"
                     f"```\n{preview}\n```\n_Starting loop..._")
            if not state.running:
                threading.Thread(target=run_loop,
                                 args=("[LOAD_TASK]",), daemon=True).start()
            else:
                post(ch, "⚠️ Loop running. Type STOP first.")
        return True
    if cmd == "SHOW_BRIEF":
        c=ws_read("intake")
        post(ch,f"📋 *intake_brief.md*\n```\n{c[:2000]}\n```")
        return True
    if cmd == "SHOW_CODE":
        c=ws_read("output")
        post(ch,f"💻 *qcai_3d.py* ({c.count(chr(10))} lines)\n"
                f"```python\n{c[:2000]}\n```")
        return True
    if cmd == "SHOW_PHYSICS":
        c=ws_read("physics")
        post(ch,f"⚛️ *physics_report.md*\n```\n{c[:2000]}\n```")
        return True
    if cmd == "SHOW_OUTPUT":
        c=ws_read("output")
        post(ch,f"🚀 *qcai_3d.py* ({c.count(chr(10))} lines)\n"
                f"```python\n{c[:3000]}\n```")
        return True
    if cmd.startswith("READ_FILE "):
        fname=raw[10:].strip()
        c=ws_read(fname)
        post(ch,f"📄 *{fname}*\n```\n{c[:2000]}\n```")
        return True

    # ── Version commands ──
    if cmd == "CHANGELOG":
        c = ws_read(CHANGELOG) if os.path.exists(CHANGELOG) else "No changelog yet."
        post(ch, f"📜 *Changelog*\n```\n{c[-2000:]}\n```")
        return True
    if cmd == "CHECKPOINT":
        code = ws_read("output")
        if "[File not found" in code:
            post(ch, "❌ No output file to checkpoint.")
        else:
            name = f"manual_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
            ckpt_save(name, code)
            post(ch, f"✅ *Checkpoint saved:* `checkpoints/{name}.py`")
        return True
    if cmd == "BEST":
        # Find best scored checkpoint
        best = ckpt_read("best_score_auto")
        if "[Checkpoint not found" in best:
            post(ch, "❌ No best checkpoint yet. Loop needs to score ≥8.")
        else:
            ws_write("output", best)
            lines = best.count('\n')
            post(ch, f"✅ *Best checkpoint restored to qcai_3d.py* ({lines} lines)")
        return True
    if cmd.startswith("ROLLBACK "):
        try:
            n = int(raw.split()[1])
            code = ver_read("output", n)
            if "[Version not found" in code:
                post(ch, f"❌ No output version for loop {n}")
            else:
                ws_write("output", code)
                lines = code.count('\n')
                post(ch, f"✅ *Rolled back to loop {n}* ({lines} lines) → qcai_3d.py")
        except (ValueError, IndexError):
            post(ch, "❌ Usage: `ROLLBACK <loop_number>`")
        return True
    if cmd.startswith("SHOW_VERSION "):
        try:
            parts = raw.split()
            n     = int(parts[1])
            agent = parts[2].lower() if len(parts)>2 else "output"
            code  = ver_read(agent, n)
            post(ch, f"📄 *Loop {n} — {agent}*\n```\n{code[:2000]}\n```")
        except (ValueError, IndexError):
            post(ch, "❌ Usage: `SHOW_VERSION <loop> [agent]`\n"
                     "Agents: intake prime builder physics output")
        return True
    if cmd.startswith("LIST_VERSIONS"):
        parts  = raw.split()
        agent  = parts[1].lower() if len(parts)>1 else "output"
        listing= list_versions(agent)
        post(ch, f"📁 *versions/{agent}/*\n```\n{listing}\n```")
        return True

    return False

# ─── Main Loop ────────────────────────────────────────────────────────────────

def run_loop(initial_input):
    with state.lock:
        state.running=True; state.paused=False; state.loop_count=0
        state.original_request=initial_input
        state.last_build=""; state.last_physics=""

    ws_init()
    task_txt = ws_read("task")
    if "[File not found" in task_txt:
        task_txt = initial_input
        ws_write("task", initial_input)

    log.info(f"Loop start: {initial_input[:60]}...")
    post_agents(
        f"🔄 *Sovereign Quad-Agent Loop v7.2 — Versioned File Mode*\n"
        f"Intake→Prime→Builder→Physics→repeat\n"
        f"Workspace: `{WS_ROOT}`\n"
        f"Each loop saves versioned files per agent.\n"
        f"Commands: `STOP` `PAUSE` `RESUME` `SHIP IT` `STATUS` `PULL_DATA`\n"
        f"Files: `LOAD_TASK` `SHOW_BRIEF` `SHOW_CODE` `SHOW_OUTPUT`\n"
        f"Versions: `ROLLBACK <N>` `CHECKPOINT` `BEST` `CHANGELOG` `LIST_VERSIONS`"
    )

    while state.running:
        state.loop_count += 1
        loop     = state.loop_count
        has_code = bool(state.last_physics or state.last_build)

        if not wait_if_paused(): break

        # ══ INTAKE ═══════════════════════════════════════════════
        prev_code = ws_read("output") if has_code else ""
        usr_in = (
            f"FULL TASK SPEC:\n{task_txt}\n\n"
            f"PREVIOUS qcai_3d.py:\n"
            f"{prev_code[:3000] if '[File not found' not in prev_code else 'None'}\n\n"
            f"LIVE RING:\n{fmt_qdata(full=True)}\n\n"
            f"Generate improvement brief for loop {loop}."
        ) if has_code else (
            f"FULL TASK SPEC:\n{task_txt}\n\n"
            f"LIVE RING:\n{fmt_qdata(full=True)}\n\nGenerate initial brief."
        )

        t = post(INTAKE_CHANNEL_ID, f"🔄 *[Loop {loop}] Intake...*")
        out = infer(make_intake_prompt(loop, has_code), usr_in,
                    temperature=0.15, max_tokens=1500)
        state.last_intake = out
        ws_write("intake", f"# Intake Brief — Loop {loop}\n\n{out}")
        ver_write("intake", loop, out, "md")

        notify = out[:300]+"..." if len(out)>300 else out
        if t.get("ts"):
            update(INTAKE_CHANNEL_ID, t["ts"],
                   f"✅ *[Loop {loop}] Intake done*\n"
                   f"Files: `intake_brief.md` + `versions/intake/loop_{loop:03d}_intake.md`\n\n"
                   f"{notify}\n\n_`SHOW_BRIEF` for full_")
        if not wait_if_paused(): break

        # ══ PRIME ════════════════════════════════════════════════
        score    = extract_score(state.last_prime)
        ship_n   = "\n⚠️ Score ≥8 last loop — type SHIP IT to finalize." if score>=8 else ""
        full_brief = ws_read("intake")

        prime_in = (
            f"TASK SPEC:\n{task_txt[:800]}\n\n"
            f"FULL INTAKE BRIEF:\n{full_brief}\n\n"
            f"PREV CODE SUMMARY:\n"
            f"{prev_code[:400] if '[File not found' not in prev_code else 'None'}"
            f"{ship_n}"
        )

        t2 = post(PRIME_CHANNEL_ID, f"🔄 *[Loop {loop}] Prime...*")
        out2 = infer(make_prime_prompt(loop), prime_in,
                     temperature=0.2, max_tokens=2000)
        state.last_prime = out2
        ws_write("prime", f"# Prime Plan — Loop {loop}\n\n{out2}")
        ver_write("prime", loop, out2, "md")

        ns = extract_score(out2)
        notify2 = out2[:300]+"..." if len(out2)>300 else out2
        if t2.get("ts"):
            update(PRIME_CHANNEL_ID, t2["ts"],
                   f"✅ *[Loop {loop}] Prime done* | Score: {ns}/10\n"
                   f"Files: `prime_plan.md` + `versions/prime/loop_{loop:03d}_prime.md`\n\n"
                   f"{notify2}")
        if ns>=8:
            post_agents(f"⭐ *[Loop {loop}] Prime scored {ns}/10 — READY TO SHIP*\n"
                        f"Type `SHIP IT` to finalize or loop continues.")
        if not wait_if_paused(): break

        # ══ BUILDER ══════════════════════════════════════════════
        full_prime = ws_read("prime")
        prev_full  = ws_read("output")

        build_in = (
            f"FULL PRIME PLAN:\n{full_prime}\n\n"
            f"TASK SPEC:\n{task_txt[:800]}\n\n"
            f"PREVIOUS qcai_3d.py (improve this):\n"
            f"{prev_full[:4000] if '[File not found' not in prev_full else 'None — write from scratch'}"
        )

        t3 = post(BUILD_CHANNEL_ID, f"🔄 *[Loop {loop}] Builder...*")
        out3 = infer(BUILDER_PROMPT, build_in, temperature=0.1, max_tokens=2000)
        state.last_build = out3
        ws_write("builder", f"# Builder Output — Loop {loop}\n\n{out3}")
        ver_write("builder", loop, out3, "py")

        code_only = extract_code(out3)
        if len(code_only) > 100:
            ws_write("output", code_only)
            ver_write("output", loop, code_only, "py")

        lines = code_only.count('\n')
        if t3.get("ts"):
            update(BUILD_CHANNEL_ID, t3["ts"],
                   f"✅ *[Loop {loop}] Builder done* | {lines} lines\n"
                   f"Files: `qcai_3d.py` + `versions/builder/loop_{loop:03d}_builder.py`\n"
                   f"       `versions/output/loop_{loop:03d}_qcai_3d.py`\n\n"
                   f"_`SHOW_CODE` to preview_")
        if not wait_if_paused(): break

        # ══ PHYSICS ══════════════════════════════════════════════
        ph_sys    = PHYSICS_PROMPT.replace("{loop}", str(loop))
        full_code = ws_read("output")
        full_prime_txt = ws_read("prime")

        physics_in = (
            f"FULL CODE (qcai_3d.py):\n{full_code[:4000]}\n\n"
            f"PRIME PHYSICS CHECKS:\n{full_prime_txt[:600]}\n\n"
            f"TASK SPEC:\n{task_txt[:400]}\n\n"
            f"LIVE RING:\n{fmt_qdata(full=True)}"
        )

        t4 = post(PHYSICS_CHANNEL_ID, f"🔄 *[Loop {loop}] Physics...*")
        out4 = infer(ph_sys, physics_in, temperature=0.05, max_tokens=2000)
        state.last_physics = out4
        ws_write("physics", f"# Physics Report — Loop {loop}\n\n{out4}")
        ver_write("physics", loop, out4, "md")

        # Extract and save corrected code
        corrected = extract_code(out4)
        phys_status = extract_physics_status(out4)
        if len(corrected) > 200:
            ws_write("output", corrected)
            ver_write("physics", loop, corrected, "py")
            ver_write("output", loop, corrected, "py")  # overwrite with physics version

        # Auto-checkpoint if Physics PASS or Prime scored ≥8
        if phys_status == "PASS":
            ckpt_save("best_physics_pass", corrected if len(corrected)>200 else full_code)
            post(PHYSICS_CHANNEL_ID, "✅ *Physics PASS — auto-checkpointed as `best_physics_pass.py`*")
        if ns >= 8 and ns > state.best_score:
            state.best_score = ns
            ckpt_save("best_score_auto", corrected if len(corrected)>200 else full_code)

        # Update logs
        summary_txt = out4[:500]
        summary_append(loop, summary_txt)
        changelog_append(loop, ns, phys_status, lines,
                         f"Physics:{phys_status} Score:{ns}/10")
        if state.quantum_data:
            metrics_append({**state.quantum_data, "loop": loop})

        notify4 = out4[:300]+"..." if len(out4)>300 else out4
        if t4.get("ts"):
            update(PHYSICS_CHANNEL_ID, t4["ts"],
                   f"✅ *[Loop {loop}] Physics done* | Status: {phys_status}\n"
                   f"Files: `physics_report.md` + `versions/physics/loop_{loop:03d}_*`\n"
                   f"Logs: `CHANGELOG.md` + `SUMMARY.md` updated\n\n"
                   f"{notify4}\n\n_`SHOW_OUTPUT` for final code_")

        log.info(f"Loop {loop} complete. Score:{ns}/10 Physics:{phys_status}")
        time.sleep(15)

    log.info("Loop ended.")
    with state.lock: state.reset()

# ─── Live Feed Listener ───────────────────────────────────────────────────────

def start_feed():
    class H(BaseHTTPRequestHandler):
        def do_POST(self):
            length = int(self.headers.get("Content-Length",0))
            body   = self.rfile.read(length)
            try:
                d = json.loads(body)
                state.quantum_data = d
                state.data_history.append(d)
                metrics_append(d)  # log every snapshot
                step = d.get("step",0)
                if step % 100 == 0 and step > 0:
                    nn = ["Omega","Guardian","Sentinel","Nexus","Storm","Sora",
                          "Echo","Iris","Sage","Kevin","Atlas","Void"]
                    outputs = d.get("node_outputs",[])
                    domains = d.get("domains",[])
                    nb = "\n".join(
                        f"  {nn[i]:<8}[{domains[i] if i<len(domains) else '?':<12}] "
                        f"PCM={d.get('pcms',[0]*12)[i]:+.3f}  "
                        f"\"{outputs[i] if i<len(outputs) else ''}\""
                        for i in range(12)
                    ) if outputs else "  [no node outputs yet]"
                    post(DATA_CHANNEL_ID,
                         f"⚛️ *Step {step}*\n"
                         f"```\ncv={d.get('cv',0):.4f}  nf={d.get('negfrac',0):.4f}  "
                         f"nc={d.get('nc_count',0)}/12  R={d.get('reward',0):.4f}\n"
                         f"{nb}\n```\n_Agents: PULL_DATA for context_")
            except Exception as e: log.error(f"Feed: {e}")
            self.send_response(200); self.end_headers()
        def log_message(self,*a): pass
    HTTPServer(("127.0.0.1",9999), H).serve_forever()

# ─── Event Handlers ───────────────────────────────────────────────────────────

BOT_USER_ID = ""

@app.event("app_mention")
def handle_mention(event, client):
    user = event.get("user","")
    if user==BOT_USER_ID: return
    text = re.sub(r"<@[A-Z0-9]+>","",event.get("text","")).strip()
    if not text: return
    ch = event.get("channel","")
    if handle_control(text, source_channel=ch): return
    if ch not in AGENT_CHANNELS:
        try:
            client.chat_postMessage(channel=ch,
                text=f"✅ QCAI v7.2 loop → <#{INTAKE_CHANNEL_ID}>\n"
                     f"Data → <#{DATA_CHANNEL_ID}> | Workspace: `{WS_ROOT}`")
        except Exception: pass
    if not state.running:
        threading.Thread(target=run_loop, args=(text,), daemon=True).start()
    else:
        post(INTAKE_CHANNEL_ID,"⚠️ Loop running. Type `STOP` first.")

@app.event("message")
def handle_message(event, client):
    if event.get("bot_id") or event.get("subtype"): return
    user = event.get("user","")
    if user==BOT_USER_ID or not user: return
    text = event.get("text","").strip()
    if not text: return
    if f"<@{BOT_USER_ID}>" in text: return
    ch = event.get("channel","")
    if handle_control(text, source_channel=ch): return
    if ch==INTAKE_CHANNEL_ID:
        if not state.running:
            threading.Thread(target=run_loop, args=(text,), daemon=True).start()
        else:
            post(INTAKE_CHANNEL_ID,"⚠️ Loop running. Type `STOP` first.")

# ─── Health + Warmup ──────────────────────────────────────────────────────────

def check_api():
    try:
        r=requests.get(f"{OPENJARVIS_API}/health",timeout=5)
        if r.status_code==200: log.info("✅ API healthy"); return True
    except Exception: pass
    log.error("❌ API not reachable"); return False

def check_tokens():
    missing=[k for k in ["SLACK_BOT_TOKEN","SLACK_APP_TOKEN","SLACK_SIGNING_SECRET"]
             if not os.environ.get(k)]
    if missing: log.error(f"❌ Missing: {', '.join(missing)}"); return False
    log.info("✅ Tokens present"); return True

def warm_model():
    try:
        requests.post(f"{OPENJARVIS_API}/v1/chat/completions",
                      json={"model":MODEL,
                            "messages":[{"role":"user","content":"hi"}],
                            "max_tokens":5},timeout=60)
        log.info("✅ Model warmed up")
    except Exception as e: log.warning(f"Warm-up: {e}")

# ─── Main ─────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    log.info("="*60)
    log.info("OpenJarvis Slack Bridge v7.2")
    log.info("Versioned File Mode + Agent Folders + Changelog")
    log.info("="*60)
    log.info(f"Channels: data={DATA_CHANNEL_ID} intake={INTAKE_CHANNEL_ID}")
    log.info(f"          prime={PRIME_CHANNEL_ID} build={BUILD_CHANNEL_ID}")
    log.info(f"          physics={PHYSICS_CHANNEL_ID}")
    log.info(f"Workspace: {WS_ROOT}")
    log.info("Commands: STOP|PAUSE|RESUME|SHIP IT|STATUS|PULL_DATA")
    log.info("Files: LOAD_TASK|SHOW_BRIEF|SHOW_CODE|SHOW_OUTPUT|CHANGELOG")
    log.info("Versions: ROLLBACK <N>|CHECKPOINT|BEST|LIST_VERSIONS|SHOW_VERSION <N>")
    log.info("="*60)

    if not check_tokens(): raise SystemExit(1)
    if not check_api():    raise SystemExit(1)

    try: BOT_USER_ID = app.client.auth_test()["user_id"]
    except Exception: pass
    log.info(f"Bot: {BOT_USER_ID}")

    ws_init()
    log.info(f"Workspace initialized: {WS_ROOT}")
    threading.Thread(target=start_feed, daemon=True).start()
    warm_model()

    log.info("Ready.")
    log.info("  LOAD_TASK — start loop from current_task.md")
    log.info("  Or drop any message in #jarvis-intake")
    log.info("="*60)

    SocketModeHandler(app, SLACK_APP_TOKEN).start()
